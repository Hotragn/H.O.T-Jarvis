# H.O.T-Jarvis — environment configuration
# Copy this file to .env and fill in what you have. Everything is optional:
# with no keys and no Ollama, the app still starts and tells you how to set up
# free inference. Never commit your real .env.

# --- Local models (default, unlimited, private) ---
# Install Ollama from https://ollama.com then run:  ollama pull llama3.2
# Base URL only needs changing if Ollama runs somewhere non-standard.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- Free cloud fallbacks (pick any; all have free tiers) ---
# Groq: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter (":free" models): https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# --- App data ---
# Where memory (SQLite) and notes live. Defaults to the OS app-data dir.
# JARVIS_DATA_DIR=

# --- Kill switch ---
# Set JARVIS_STOP=1 (or create a .jarvis/STOP file) to halt any autonomous loop.
# JARVIS_STOP=
